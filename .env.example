# Base de datos (local dev: docker-compose.yml levanta este Postgres)
DATABASE_URL="postgresql://arandusoft:arandusoft@localhost:5432/arandusoft?schema=public"

# NextAuth
NEXTAUTH_SECRET="genera-uno-con-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="no-reply@criterioasesores.com.py"

# Storage (MinIO — self-hosted, compatible S3). Archivos privados,
# descarga siempre vía URL firmada.
MINIO_ENDPOINT="https://storage.tudominio.com"
MINIO_ACCESS_KEY=""
MINIO_SECRET_KEY=""
MINIO_BUCKET="arandufiles"

# Superadmin (seed inicial, no exponer al cliente)
SUPERADMIN_EMAIL=""
SUPERADMIN_PASSWORD_HASH=""

# Cifrado del campo Cliente.accesos (AES-256-GCM) — 32 bytes en base64
ENCRYPTION_KEY=""

# Cron diario (/api/cron/daily) — header x-cron-secret
CRON_SECRET=""

# Envío de archivos por correo interno
RESEND_ATTACHMENT_MAX_BYTES=8388608

# Feature flag módulo jurídico (Fase 2)
NEXT_PUBLIC_ENABLE_JURIDICO=false
